{
  "title": "Aggregator",
  "uid": "aggregator-main",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Round Phase Breakdown (Child/Fleet, 15s avg)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(aggregator_parent_root_submission_duration_seconds_sum{role=\"child\"}[15s])) / sum(rate(aggregator_parent_root_submission_duration_seconds_count{role=\"child\"}[15s]))",
          "legendFormat": "root submission avg",
          "refId": "A"
        },
        {
          "expr": "sum(rate(aggregator_parent_proof_wait_duration_seconds_sum{role=\"child\"}[15s])) / sum(rate(aggregator_parent_proof_wait_duration_seconds_count{role=\"child\"}[15s]))",
          "legendFormat": "proof wait avg",
          "refId": "B"
        },
        {
          "expr": "sum(rate(aggregator_round_finalization_duration_seconds_sum{role=\"child\"}[15s])) / sum(rate(aggregator_round_finalization_duration_seconds_count{role=\"child\"}[15s]))",
          "legendFormat": "finalization avg",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Block Creation Time Buckets (Child, % All-Time)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.1\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.0\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.0,1.1]s",
          "refId": "A"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.2\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.1\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.1,1.2]s",
          "refId": "C"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.3\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.2\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.2,1.3]s",
          "refId": "D"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.5\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.3\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.3,1.5]s",
          "refId": "E"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.8\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.5\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.5,1.8]s",
          "refId": "F"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"2.2\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"1.8\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.8,2.2]s",
          "refId": "G"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"2.6\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"2.2\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(2.2,2.6]s",
          "refId": "H"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"3.0\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"2.6\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(2.6,3.0]s",
          "refId": "I"
        },
        {
          "expr": "100 * (sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"+Inf\"}) - sum(aggregator_block_creation_duration_seconds_bucket{role=\"child\",le=\"3.0\"})) / clamp_min(sum(aggregator_block_creation_duration_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": ">3.0s",
          "refId": "J"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "vertical",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 3,
      "title": "Commitments per Round (Child Avg, 15s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (instance, shard) (rate(aggregator_round_commitments_sum{role=\"child\"}[15s])) / sum by (instance, shard) (rate(aggregator_round_commitments_count{role=\"child\"}[15s]))",
          "legendFormat": "{{instance}} (shard {{shard}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Commitment Queue Depth (Child)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "aggregator_commitment_queue_backlog{role=\"child\"}",
          "legendFormat": "{{instance}} ({{shard}}) backlog",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 5,
      "title": "BFT Certification Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(aggregator_bft_certification_duration_seconds_bucket{role!=\"child\"}[2m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aggregator_bft_certification_duration_seconds_bucket{role!=\"child\"}[2m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(aggregator_bft_errors_total[1m])",
          "legendFormat": "{{instance}} ({{shard}}) BFT errors/sec",
          "refId": "A"
        },
        {
          "expr": "rate(aggregator_parent_proof_errors_total{role=\"child\"}[1m])",
          "legendFormat": "{{instance}} ({{shard}}) parent proof errors/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "title": "HTTP Request Rate by Method",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(aggregator_http_requests_total[15s])",
          "legendFormat": "{{instance}} ({{shard}}) {{method}}/{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP Request Latency by Method (Avg, 15s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(aggregator_http_request_duration_seconds_sum[15s]) / rate(aggregator_http_request_duration_seconds_count[15s])",
          "legendFormat": "{{instance}} ({{shard}}) avg {{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 10,
      "title": "SMT Persisted Node Count",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "aggregator_smt_nodes_persisted_total",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 12,
      "title": "Block Height by Instance",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 32
      },
      "targets": [
        {
          "expr": "aggregator_block_height",
          "legendFormat": "{{instance}} ({{role}}/{{shard}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 13,
      "title": "Round Phase Breakdown (Standalone/Parent, 15s avg)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(aggregator_round_preparation_duration_seconds_sum{role!=\"child\"}[15s])) / sum(rate(aggregator_round_preparation_duration_seconds_count{role!=\"child\"}[15s]))",
          "legendFormat": "collection avg",
          "refId": "A"
        },
        {
          "expr": "sum(rate(aggregator_bft_certification_duration_seconds_sum{role!=\"child\"}[15s])) / sum(rate(aggregator_bft_certification_duration_seconds_count{role!=\"child\"}[15s]))",
          "legendFormat": "BFT certification avg",
          "refId": "B"
        },
        {
          "expr": "sum(rate(aggregator_round_finalization_duration_seconds_sum{role!=\"child\"}[15s])) / sum(rate(aggregator_round_finalization_duration_seconds_count{role!=\"child\"}[15s]))",
          "legendFormat": "finalization avg",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Child Phase Avg Latency by Instance (15s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "targets": [
        {
          "expr": "rate(aggregator_parent_root_submission_duration_seconds_sum{role=\"child\"}[15s]) / rate(aggregator_parent_root_submission_duration_seconds_count{role=\"child\"}[15s])",
          "legendFormat": "root submit {{instance}} ({{shard}})",
          "refId": "A"
        },
        {
          "expr": "rate(aggregator_parent_proof_wait_duration_seconds_sum{role=\"child\"}[15s]) / rate(aggregator_parent_proof_wait_duration_seconds_count{role=\"child\"}[15s])",
          "legendFormat": "proof wait {{instance}} ({{shard}})",
          "refId": "B"
        },
        {
          "expr": "rate(aggregator_round_finalization_duration_seconds_sum{role=\"child\"}[15s]) / rate(aggregator_round_finalization_duration_seconds_count{role=\"child\"}[15s])",
          "legendFormat": "finalization {{instance}} ({{shard}})",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Commitments/sec (Child, 15s rate)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "targets": [
        {
          "expr": "rate(aggregator_commitments_processed_total{role=\"child\"}[15s])",
          "legendFormat": "{{instance}} (shard {{shard}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 18,
      "title": "Proof Readiness Buckets (All Child Shards, % All-Time)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 52
      },
      "targets": [
        {
          "expr": "100 * sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"1.4\"}) / clamp_min(sum(aggregator_proof_readiness_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "<=1.4s",
          "refId": "A"
        },
        {
          "expr": "100 * (sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"2.0\"}) - sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"1.4\"})) / clamp_min(sum(aggregator_proof_readiness_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(1.4,2.0]s",
          "refId": "B"
        },
        {
          "expr": "100 * (sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"2.5\"}) - sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"2.0\"})) / clamp_min(sum(aggregator_proof_readiness_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(2.0,2.5]s",
          "refId": "C"
        },
        {
          "expr": "100 * (sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"3.0\"}) - sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"2.5\"})) / clamp_min(sum(aggregator_proof_readiness_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(2.5,3.0]s",
          "refId": "D"
        },
        {
          "expr": "100 * (sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"4.0\"}) - sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"3.0\"})) / clamp_min(sum(aggregator_proof_readiness_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": "(3.0,4.0]s",
          "refId": "E"
        },
        {
          "expr": "100 * (sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"+Inf\"}) - sum(aggregator_proof_readiness_seconds_bucket{role=\"child\",le=\"4.0\"})) / clamp_min(sum(aggregator_proof_readiness_seconds_count{role=\"child\"}), 1)",
          "instant": true,
          "legendFormat": ">4.0s",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "vertical",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    }
  ]
}
